# Copy to .env and fill in for local dev (`source .env` before `streamlit run app.py`),
# or create the equivalent Beam secrets for deployment (see start_server.py).

# Slack Incoming Webhook, e.g. https://hooks.slack.com/services/T000/B000/XXXX
SLACK_WEBHOOK_URL=

# Email (SMTP) — only needed if you plan to use the Email tab
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
